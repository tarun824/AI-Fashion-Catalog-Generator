OPENAI_API_KEY=your_openai_key_here
PORT=5000
OPENAI_VISION_MODEL=gpt-4o-mini
MAX_BATCH_SIZE=200
MAX_IMAGE_MB=10
WORKER_CONCURRENCY=4
ALLOWED_ORIGINS=http://localhost:5173
DESCRIPTION_PROMPT=Review this garment image and fill every bullet. Favor exact fashion terminology.
ESTIMATE_IMAGE_SECONDS=20
EXPORT_DESCRIPTION_LINES=4

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/fashion-catalog
MONGODB_GRIDFS_BUCKET=product-images

# JWT Authentication
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Default Admin Credentials (change after first login)
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_PASSWORD=

